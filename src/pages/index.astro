    <style>
      :root {
        /* Paleta exacta extraída del logo en /public/logo.jpg */
        --azul: #5BC4ED;          /* cyan cielo — borde del logo + olas */
        --azul-deep: #2A8FDB;     /* azul más profundo — "RESIDENCIAL" */
        --azul-claro: #E5F4FB;    /* lavado claro derivado para fondos suaves */
        --amarillo: #FFCB05;      /* amarillo puro brillante — top del sol y "Bellavista" */
        --naranja: #F57C00;       /* naranja cálido profundo — base del sol y "Bellavista" */
        --negro: #0F0F0F;         /* casi negro — faro y "DE PACASMAYO" */
        /* Apoyos (no son del logo, pero ya estaban en el flyer original) */
        --rojo: #c1121f;          /* solo urgencia: sticker promo + escasez */
        --verde-wa: #00b60a;      /* verde WhatsApp (botón CTA) */
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      html { scroll-behavior: smooth; }

      body {
        background:
          radial-gradient(800px 400px at 50% -8%, rgba(255, 203, 5, 0.18), transparent 70%),
          linear-gradient(180deg, #FDF8EE 0%, #F4ECD8 100%);
        color: var(--negro);
        font-family: 'Poppins', 'Segoe UI', Tahoma, sans-serif;
        min-height: 100vh;
        overflow-x: hidden;
      }

      .container {
        max-width: 480px;
        margin: 0 auto;
        padding: 1.5rem 1.2rem 3rem;
        text-align: center;
      }

      /* Logo Bellavista circular — anchor de marca arriba del hero */
      .logo-marca {
        width: 125px;
        height: 125px;
        margin: 0 auto 0.9rem;
        border-radius: 50%;
        overflow: hidden;
        background: #fff;
        box-shadow:
          0 0 0 3px #fff,
          0 0 0 6px var(--azul),
          0 12px 30px rgba(15, 15, 15, 0.3);
        position: relative;
        animation: logoEntrada 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) both;
      }

      .logo-marca img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        display: block;
        transform: scale(1.42);
        transform-origin: center;
      }

      @keyframes logoEntrada {
        0% { opacity: 0; transform: scale(0.4) rotate(-15deg); }
        60% { transform: scale(1.06) rotate(2deg); }
        100% { opacity: 1; transform: scale(1) rotate(0); }
      }

      @media (min-width: 600px) {
        .logo-marca { width: 145px; height: 145px; }
      }

      /* Banner / etiqueta destacada */
      .badge {
        display: inline-block;
        background: linear-gradient(90deg, #FFCB05, #F57C00);
        color: var(--negro);
        font-weight: 800;
        font-size: 0.85rem;
        padding: 0.45rem 1.1rem;
        border-radius: 999px;
        letter-spacing: 1px;
        text-transform: uppercase;
        box-shadow: 0 6px 16px rgba(245, 124, 0, 0.4);
        margin-bottom: 1rem;
        animation: pulse 2s infinite;
      }

      @keyframes pulse {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.05); }
      }

      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
      }

      .container > * {
        animation: fadeUp 0.6s ease-out both;
      }
      .container > *:nth-child(2) { animation-delay: 0.05s; }
      .container > *:nth-child(3) { animation-delay: 0.10s; }
      .container > *:nth-child(4) { animation-delay: 0.15s; }
      .container > *:nth-child(5) { animation-delay: 0.20s; }
      .container > *:nth-child(6) { animation-delay: 0.25s; }
      .container > *:nth-child(7) { animation-delay: 0.30s; }
      .container > *:nth-child(8) { animation-delay: 0.35s; }

      h1 {
        font-size: 1.75rem;
        font-weight: 800;
        line-height: 1.15;
        margin-bottom: 0.4rem;
        color: var(--negro);
      }

      h1 .kicker {
        display: block;
        font-size: 0.95rem;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: #fff;
        background: var(--azul-deep);
        padding: 0.3rem 0.9rem;
        border-radius: 999px;
        margin: 0 auto 0.3rem;
        width: fit-content;
      }

      h1 .destacado {
        display: block;
        font-family: 'Pacifico', cursive;
        font-size: 3rem;
        font-weight: 400;
        line-height: 1.05;
        background: linear-gradient(180deg, #FFCB05 0%, #FFB300 50%, #F57C00 100%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        margin-top: 0.3rem;
        letter-spacing: 0;
        text-transform: none;
        filter:
          drop-shadow(0 1px 0 rgba(15, 15, 15, 0.35))
          drop-shadow(0 3px 4px rgba(15, 15, 15, 0.2));
      }

      .subtitulo {
        font-size: 1.1rem;
        font-style: italic;
        font-weight: 500;
        color: var(--azul-deep);
        margin-top: 0.5rem;
        line-height: 1.4;
      }

      /* Imagen hero */
      .hero-image {
        width: 100%;
        margin: 1.2rem 0;
        border-radius: 10px;
        overflow: hidden;
        border: 2px solid var(--amarillo);
        box-shadow:
          0 0 0 1px rgba(15, 15, 15, 0.08),
          0 14px 34px rgba(15, 15, 15, 0.28);
        position: relative;
      }

      .hero-image img {
        width: 100%;
        height: auto;
        display: block;
        transition: transform 0.6s ease;
      }

      .hero-image:hover img { transform: scale(1.04); }

      .hero-image::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, transparent 65%, rgba(42, 143, 219, 0.28) 100%);
        pointer-events: none;
      }

      /* CTA arriba — botón PRINCIPAL de la página, debe ser el más destacado.
         Verde WhatsApp (reconocible) + tamaño grande + glow fuerte. */
      .cta-arriba {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.6rem;
        background: linear-gradient(135deg, #00a209 0%, #00c70b 50%, #1ee021 100%);
        color: #fff;
        font-weight: 900;
        font-size: 1.05rem;
        padding: 1.2rem 1.1rem;
        border-radius: 16px;
        text-decoration: none;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        line-height: 1.2;
        box-shadow:
          0 14px 30px rgba(0, 182, 10, 0.55),
          inset 0 -3px 0 rgba(0, 0, 0, 0.15);
        margin: 0.6rem 0 1.2rem;
        transition: transform 0.15s ease, box-shadow 0.2s ease, filter 0.2s ease;
        position: relative;
        overflow: hidden;
        animation: ctaPulse 2.2s ease-in-out 1s infinite;
        text-shadow: 0 1px 2px rgba(0, 0, 0, 0.25);
      }

      .cta-arriba:hover {
        transform: translateY(-3px);
        box-shadow:
          0 18px 38px rgba(0, 182, 10, 0.7),
          inset 0 -3px 0 rgba(0, 0, 0, 0.15);
        filter: brightness(1.05);
      }

      .cta-arriba:active { transform: translateY(0); }

      .cta-arriba::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(120deg, transparent 30%, rgba(255, 255, 255, 0.35) 50%, transparent 70%);
        transform: translateX(-100%);
        animation: ctaShine 3.5s ease-in-out 2s infinite;
      }

      .cta-arriba-ico { font-size: 1.6rem; line-height: 1; flex-shrink: 0; }
      .cta-arriba-arrow { font-size: 1.4rem; transition: transform 0.2s ease; flex-shrink: 0; }
      .cta-arriba:hover .cta-arriba-arrow { transform: translateX(5px); }

      @keyframes ctaPulse {
        0%, 100% {
          box-shadow:
            0 14px 30px rgba(0, 182, 10, 0.55),
            inset 0 -3px 0 rgba(0, 0, 0, 0.15);
        }
        50% {
          box-shadow:
            0 16px 38px rgba(0, 182, 10, 0.8),
            0 0 0 8px rgba(0, 182, 10, 0.2),
            inset 0 -3px 0 rgba(0, 0, 0, 0.15);
        }
      }

      @keyframes ctaShine {
        0%, 100% { transform: translateX(-100%); }
        50% { transform: translateX(100%); }
      }

      /* Tira lifestyle playa */
      .lifestyle-band {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0.4rem;
        margin: 0.8rem 0 1.2rem;
        background: rgba(255, 255, 255, 0.78);
        border: 1px solid rgba(255, 255, 255, 0.9);
        border-radius: 16px;
        padding: 0.9rem 0.4rem;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        box-shadow: 0 8px 20px rgba(13, 71, 161, 0.2);
      }

      .lf-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.35rem;
        text-align: center;
      }

      .lf-ico {
        font-size: 1.7rem;
        line-height: 1;
      }

      .lf-text {
        font-size: 0.7rem;
        font-weight: 700;
        color: var(--negro);
        line-height: 1.15;
      }

      /* Onda SVG divisora — eco visual del logo Bellavista */
      .wave-divider {
        width: 100%;
        height: 28px;
        display: block;
        margin: 0.4rem 0;
        color: var(--naranja);
        opacity: 0.55;
      }

      /* Sección de amenidades */
      .amenidades-titulo {
        font-size: 1.1rem;
        font-weight: 800;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        margin: 1.8rem 0 0.5rem;
        color: var(--negro);
      }

      .amenidades-titulo::after {
        content: '';
        display: block;
        width: 55px;
        height: 3px;
        background: linear-gradient(90deg, #FFCB05, #F57C00);
        border-radius: 2px;
        margin: 0.4rem auto 0;
      }

      .amenidades-sub {
        font-size: 0.92rem;
        font-weight: 500;
        color: var(--negro);
        margin-bottom: 0.8rem;
      }

      /* Beneficios / features — tarjetas blancas */
      .features {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.65rem;
        margin: 1.2rem 0;
      }

      .feature {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border: 2px solid var(--amarillo);
        border-radius: 12px;
        padding: 0.9rem 0.6rem;
        font-size: 0.88rem;
        font-weight: 700;
        line-height: 1.3;
        color: var(--negro);
        box-shadow: 0 6px 16px rgba(13, 71, 161, 0.18);
        transition: transform 0.2s ease, border-color 0.2s ease;
      }

      .feature:hover {
        transform: translateY(-2px);
        border-color: var(--azul);
      }

      .feature .icono {
        font-size: 1.55rem;
        display: block;
        margin-bottom: 0.3rem;
      }

      .ubicacion {
        font-size: 0.95rem;
        font-weight: 600;
        margin: 1rem 0;
        color: var(--negro);
        line-height: 1.4;
      }

      .ubicacion strong { color: var(--rojo); }

      .escasez {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(255, 255, 255, 0.92);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border: 2px solid var(--rojo);
        color: var(--rojo);
        font-size: 0.85rem;
        font-weight: 800;
        padding: 0.5rem 0.9rem;
        border-radius: 999px;
        margin: 0.6rem 0 0.2rem;
        box-shadow: 0 6px 16px rgba(193, 18, 31, 0.3);
      }

      .escasez .dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--rojo);
        box-shadow: 0 0 0 0 rgba(193, 18, 31, 0.7);
        animation: blink 1.4s infinite;
      }

      @keyframes blink {
        0% { box-shadow: 0 0 0 0 rgba(193, 18, 31, 0.7); }
        70% { box-shadow: 0 0 0 10px rgba(193, 18, 31, 0); }
        100% { box-shadow: 0 0 0 0 rgba(193, 18, 31, 0); }
      }

      /* Formulario — glass card */
      .form-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 2px solid var(--amarillo);
        border-radius: 20px;
        padding: 1.6rem 1.2rem;
        margin-top: 1.5rem;
        box-shadow: 0 18px 40px rgba(13, 71, 161, 0.3);
      }

      .form-card h3 {
        font-size: 1.2rem;
        font-weight: 800;
        margin-bottom: 1rem;
        color: var(--negro);
      }

      form {
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
      }

      input {
        padding: 1rem 1.05rem;
        border-radius: 12px;
        border: 2px solid rgba(91, 196, 237, 0.5);
        font-size: 1rem;
        background: rgba(255, 255, 255, 0.85);
        color: var(--negro);
        transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
      }

      input:focus {
        outline: none;
        border-color: var(--amarillo);
        box-shadow: 0 0 0 4px rgba(255, 203, 5, 0.3);
        background: #fff;
      }

      button {
        background: linear-gradient(90deg, #00b60a, #00d40c);
        color: white;
        font-weight: 800;
        font-size: 1.1rem;
        padding: 1.15rem;
        border: none;
        border-radius: 14px;
        cursor: pointer;
        box-shadow: 0 10px 22px rgba(0, 182, 10, 0.5);
        transition: transform 0.15s ease, box-shadow 0.2s ease, filter 0.2s ease;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        position: relative;
        overflow: hidden;
      }

      button::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(120deg, transparent 30%, rgba(255,255,255,0.35) 50%, transparent 70%);
        transform: translateX(-100%);
        transition: transform 0.6s ease;
      }

      button:hover {
        transform: translateY(-2px);
        box-shadow: 0 14px 30px rgba(0, 182, 10, 0.65);
        filter: brightness(1.05);
      }

      button:hover::before { transform: translateX(100%); }

      button:active { transform: translateY(0); }

      .trust {
        margin-top: 1rem;
        font-size: 0.82rem;
        font-weight: 500;
        color: var(--negro);
      }

      .trust-row {
        display: flex;
        justify-content: center;
        gap: 1rem;
        flex-wrap: wrap;
        margin-top: 1.2rem;
        font-size: 0.82rem;
        font-weight: 600;
        color: var(--negro);
      }

      .trust-row span {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
      }

      @media (min-width: 600px) {
        h1 { font-size: 2.1rem; }
        h1 .destacado { font-size: 3.6rem; }
        h1 .kicker { font-size: 1.05rem; }
        .lf-ico { font-size: 1.9rem; }
        .lf-text { font-size: 0.78rem; }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="logo-marca">
        <img src="/logo.jpg" alt="Logo Residencial Bellavista de Pacasmayo" />
      </div>

      <span class="badge">🌊 Oportunidad de Inversión Frente al Mar</span>

      <h1>
        <span class="kicker">Tu Lote en</span>
        <span class="destacado">Bellavista de Pacasmayo</span>
      </h1>
      <p class="subtitulo">Vive a 5 minutos de la playa o invierte hoy con financiamiento directo.</p>

      <div class="hero-image">
        <img src="/bellavista.jpg" alt="Residencial Bellavista de Pacasmayo" />
      </div>

      <a href="/gracias" class="cta-arriba" aria-label="Únete al grupo de WhatsApp para más información">
        <span class="cta-arriba-ico">📲</span>
        <span>Únete al grupo de WhatsApp</span>
        <span class="cta-arriba-arrow">➜</span>
      </a>

      <div class="lifestyle-band">
        <div class="lf-item">
          <span class="lf-ico">🌅</span>
          <span class="lf-text">Atardeceres únicos</span>
        </div>
        <div class="lf-item">
          <span class="lf-ico">🏄</span>
          <span class="lf-text">Surf y playa</span>
        </div>
        <div class="lf-item">
          <span class="lf-ico">🐟</span>
          <span class="lf-text">Mariscos frescos</span>
        </div>
        <div class="lf-item">
          <span class="lf-ico">☀️</span>
          <span class="lf-text">Clima cálido todo el año</span>
        </div>
      </div>

      <p class="ubicacion">
        🏖️ A <strong>5 minutos de la Playa de Pacasmayo</strong> · Inscritos en Registros Públicos
      </p>

      <svg class="wave-divider" viewBox="0 0 1440 60" preserveAspectRatio="none" aria-hidden="true">
        <path d="M0,30 C240,55 480,5 720,30 C960,55 1200,5 1440,30 L1440,60 L0,60 Z" fill="currentColor"/>
      </svg>

      <div class="features">
        <div class="feature">
          <span class="icono">🌊</span>
          A 5 min de la playa
        </div>
        <div class="feature">
          <span class="icono">☀️</span>
          Ideal para casa de playa
        </div>
        <div class="feature">
          <span class="icono">📄</span>
          Inscritos en Registros Públicos
        </div>
        <div class="feature">
          <span class="icono">✅</span>
          Financiamiento directo
        </div>
        <div class="feature">
          <span class="icono">💰</span>
          Inicial desde S/. 2,500
        </div>
        <div class="feature">
          <span class="icono">🗓️</span>
          Hasta 36 meses
        </div>
      </div>

      <h2 class="amenidades-titulo">Amenidades del Proyecto</h2>
      <p class="amenidades-sub">Pórtico de ingreso · Parques · Veredas · Lozas deportivas</p>
      <div class="hero-image">
        <img src="/bellavista%202.jpg" alt="Amenidades: Pórtico de ingreso, parques modernos, veredas y lozas deportivas" loading="lazy" />
      </div>

      <div class="escasez">
        <span class="dot"></span>
        Pocos lotes disponibles · Promoción por tiempo limitado
      </div>

      <svg class="wave-divider" viewBox="0 0 1440 60" preserveAspectRatio="none" aria-hidden="true">
        <path d="M0,30 C240,55 480,5 720,30 C960,55 1200,5 1440,30 L1440,60 L0,60 Z" fill="currentColor"/>
      </svg>

      <div class="form-card">
        <h3>📲 Regístrate y únete al grupo de WhatsApp</h3>
        <form id="formulario">
          <input type="text" name="nombre" placeholder="Tus nombres" required />
          <input type="tel" name="telefono" placeholder="Tu número de WhatsApp" required />
          <button type="submit">Quiero Más Información ➜</button>
        </form>
        <p class="trust">🔒 Tus datos están seguros con nosotros</p>
      </div>

      <div class="trust-row">
        <span>📄 Registros Públicos</span>
        <span>💼 Financiamiento directo</span>
        <span>🤝 Atención inmediata</span>
      </div>
    </div>

    <script>
      document.getElementById("formulario").addEventListener("submit", (e) => {
        e.preventDefault();
        window.location.href = "/gracias";
      });
    </script>
  </body>
</html>
