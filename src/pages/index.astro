<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>Residencial Bellavista de Pacasmayo | COVARO</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Residencial Bellavista de Pacasmayo: lotes desde S/. 18,000, inicial desde S/. 2,500 y financiamiento directo hasta 36 meses. A 5 minutos de la playa. Inscritos en Registros Públicos." />

    <!-- Google Fonts: Poppins (body) + Pacifico (script para el título marca) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Poppins:wght@400;600;700;800;900&display=swap" rel="stylesheet" />

